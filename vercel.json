{
    "builds": [
        {
            "src": "api/index.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "api/index.py"
        },
        {
            "src": "/js/env.js",
            "dest": "api/index.py"
        },
        {
            "src": "/(.*\\.(css|js|png|svg|jpg|ico|json|webmanifest|html))",
            "dest": "$1"
        },
        {
            "src": "/(.*)",
            "dest": "/login.html"
        }
    ],
    "env": {
        "PYTHONPATH": "."
    }
}