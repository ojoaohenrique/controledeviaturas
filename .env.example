# Supabase Configuration
# Get these values from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# Database Connection String (SQLAlchemy format)
# Example: postgresql+psycopg2://postgres.user:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=

# Flask Configuration
FLASK_SECRET_KEY=your-secret-key-here
FLASK_DEBUG=0
PORT=5000
# Optional: Set to 1 to enable CORS for all origins (not recommended for production)
ENABLE_CORS=0
    